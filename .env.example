# Poshmark credentials
POSHMARK_EMAIL=your@email.com
POSHMARK_PASSWORD=yourpassword

# Google Cloud (service account JSON — paste the whole JSON blob or path to file)
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json

# Google Drive & Sheets IDs
# Poshmark folder: <your-poshmark-folder-id>
# Inputs folder (where item folders go): <your-inputs-folder-id>
DRIVE_FOLDER_ID=<your-inputs-folder-id>
SPREADSHEET_ID=<your-spreadsheet-id>

# Telegram (for notifications)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>

# OpenAI / Vision (optional — for image analysis; falls back to description prompting via LLM)
OPENAI_API_KEY=sk-...

# App
NODE_ENV=development
LOG_LEVEL=info
