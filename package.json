{
  "name": "poshmark-store",
  "version": "0.1.0",
  "description": "Automated Poshmark selling pipeline — photos in Drive, AI analysis, Playwright browser automation, Google Sheets tracking",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test:post": "tsx src/test-post.ts",
    "inspect:poshmark-api": "tsx src/inspect-poshmark-api.ts",
    "poshmark:auth:request": "tsx src/inspect-poshmark-api.ts",
    "poshmark:auth:submit": "tsx src/inspect-poshmark-api.ts",
    "test": "vitest",
    "test:ci": "vitest run --reporter=default",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "googleapis": "^146.0.0",
    "playwright": "^1.51.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
